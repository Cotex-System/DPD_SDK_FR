# =========================
# DPD SDK - Environment
# =========================

# Environnement actif: test | prod
DPD_ENV=test

# -------------------------
# Credentials (fallback)
# -------------------------
# Utilisés si les variables spécifiques à l'environnement ne sont pas définies.
DPD_USERID=
DPD_PASSWORD=

# ---------------------------------
# Credentials spécifiques TEST/PROD
# ---------------------------------
DPD_TEST_USERID=
DPD_TEST_PASSWORD=
DPD_RUN_LIVE_TESTS=
DPD_PROD_USERID=
DPD_PROD_PASSWORD=

# -------------------------
# SOAP endpoints (fallback)
# -------------------------
# Utilisés si les variables spécifiques à l'environnement ne sont pas définies.
DPD_EPRINT_WSDL=https://e-station-testenv.cargonet.software/eprintwebservice/eprintwebservice.asmx?WSDL
DPD_TRACE_WSDL=https://e-station-testenv.cargonet.software/trace-service/Webtrace_Service.asmx?WSDL

DPD_EPRINT_LOCATION=https://e-station-testenv.cargonet.software/eprintwebservice/eprintwebservice.asmx
DPD_TRACE_LOCATION=https://e-station-testenv.cargonet.software/trace-service/Webtrace_Service.asmx

# --------------------------------------
# SOAP endpoints spécifiques TEST / PROD
# --------------------------------------
# TEST
DPD_TEST_EPRINT_WSDL=https://e-station-testenv.cargonet.software/eprintwebservice/eprintwebservice.asmx?WSDL
DPD_TEST_TRACE_WSDL=https://e-station-testenv.cargonet.software/trace-service/Webtrace_Service.asmx?WSDL

DPD_TEST_EPRINT_LOCATION=https://e-station-testenv.cargonet.software/eprintwebservice/eprintwebservice.asmx
DPD_TEST_TRACE_LOCATION=https://e-station-testenv.cargonet.software/trace-service/Webtrace_Service.asmx

# PROD (à renseigner avec les URLs de production fournies par DPD)
DPD_PROD_EPRINT_WSDL=https://e-station.cargonet.software/dpd-eprintwebservice/eprintwebservice.asmx?WSDL
DPD_PROD_TRACE_WSDL=https://webtrace.dpd.fr/trace-service/Webtrace_Service.asmx?WSDL

DPD_PROD_EPRINT_LOCATION=https://e-station.cargonet.software/dpd-eprintwebservice/eprintwebservice.asmx
DPD_PROD_TRACE_LOCATION=https://webtrace.dpd.fr/trace-service/Webtrace_Service.asmx

# -------------------------
# Options SOAP optionnelles
# -------------------------
# Ces valeurs peuvent aussi être passées en code via Config.
# Exemple:
# DPD_SOAP_CONNECTION_TIMEOUT=20
# DPD_SOAP_ENCODING=UTF-8

# -------------------------
# Live tests (optionnel)
# -------------------------
# Active les tests réseau réels PHPUnit
DPD_RUN_LIVE_TESTS=0
# Active les tests live étendus pour tous les endpoints (EPrint + Trace)
DPD_LIVE_ENABLE_ALL_ENDPOINT_TESTS=0

# Contexte métier pour les tests live avancés (GetShipping, GetLastTraceBc, etc.)
DPD_LIVE_COUNTRYCODE=
DPD_LIVE_CENTERNUMBER=
DPD_LIVE_CUSTOMER_NUMBER=
DPD_LIVE_LANGUAGE=FR
DPD_LIVE_SHIPPING_DATE=

# Données trace optionnelles pour les tests live de recherche
# Si vides, les tests tentent de créer/récupérer dynamiquement les valeurs via EPrint (create/get)
DPD_LIVE_TRACE_SHIPMENT_NUMBER=
DPD_LIVE_TRACE_PARCEL=
DPD_LIVE_TRACE_REFERENCE=

# Contexte complémentaire pour endpoints EPrint étendus
DPD_LIVE_RETOUR_COUNTRYCODE=
DPD_LIVE_RETOUR_CENTERNUMBER=
# Les variables ci-dessous sont optionnelles: les tests tentent de les déduire d'une création/récupération préalable
DPD_LIVE_RETOUR_PARCELNUMBER=
DPD_LIVE_RETOUR_NUMBER=
DPD_LIVE_RETOUR_ORIGINAL_BARCODE=
DPD_LIVE_TERMINATE_COLLECTION_BARCODE=
DPD_LIVE_TERMINATE_COLLECTION_PARCELNUMBER=
DPD_LIVE_TERMINATE_BARCODE_ID=
DPD_LIVE_NOTICE_BARCODE_ID=
DPD_LIVE_NOTICE_BARCODE_SOURCE=
DPD_LIVE_NOTICE_ANSWER_ID=
