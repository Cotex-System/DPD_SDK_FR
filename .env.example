# Variables d'environnement pour le SDK DPD France

# Identifiants DPD API
DPD_USERNAME=votre_username_dpd
DPD_PASSWORD=votre_password_dpd

# Environnement (production ou sandbox)
DPD_ENVIRONMENT=production

# URL personnalisée (optionnel - si vous n'utilisez pas l'environnement par défaut)
# DPD_BASE_URL=https://custom-api-url.com/api/v1

# Timeouts (optionnel)
DPD_TIMEOUT=30
DPD_CONNECT_TIMEOUT=10

# SSL Verification (optionnel - à utiliser avec précaution en dev uniquement)
DPD_VERIFY_SSL=true
